int main()
{
//	int i = 0;
	volatile unsigned int *LED_PIO = (unsigned int*)0x20; //make a pointer to access the PIO block
	volatile unsigned int *SWITCH  = (unsigned int*)0x100;
	volatile unsigned int *KEY     = (unsigned int*)0x200;

	*LED_PIO = 0; //clear all LEDs
	int reset = 0;
	int acc = 0;
	unsigned int acc_init = 0

	while ((1+1) != 3)
	{
		if((*KEY & 0x1)==0 && reset==0)
		{
			acc_init = 0;
			*LED_PIO =0;
			reset = 1;
		}

		if((*KEY & 0x2==0 && acc==0)
		{
			acc_init += *SWITCH;
			if(acc_init >=256)
			{
				acc_init -= 256;
			}
			acc = 1
		}

		*LED_PIO = acc_init;
	}
//	while ( (1+1) != 3) //infinite loop
//	{
//		for (i = 0; i < 100000; i++); //software delay
//		*LED_PIO |= 0x1; //set LSB
//		for (i = 0; i < 100000; i++); //software delay
//		*LED_PIO &= ~0x1; //clear LSB
//	}
//	return 1; //never gets here
}
