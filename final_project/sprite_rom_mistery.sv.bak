// sprite_rom.sv
//
// stores data about enemy sprites

module sprite_rom0
(
	input 	[7:0] addr,
	output 	[7:0] data
);

	logic[7:0] addr_reg;

	parameter [0:16][7:0] ROM = {

		8'b10000010, //0 █     █ 
		8'b01111100, //1  █████  
		8'b01000100, //2  █   █  
		8'b01010100, //3  █ █ █  
		8'b11111110, //4 ███████
		8'b00111000, //5   ███   
		8'b01010100, //6  █ █ █  
		8'b00000000, //7 
		
		8'b00100010, //8   █   █ 
		8'b00111110, //9   █████  
		8'b00100010, //10  █   █  
		8'b00101010, //11  █ █ █  
		8'b01111111, //12 ███████
		8'b00011100, //13   ███   
		8'b00101010, //14  █ █ █  
		8'b00000000, //15	

		
	};

	assign data = ROM[addr];
	
endmodule 