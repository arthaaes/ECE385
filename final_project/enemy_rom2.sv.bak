// enemy_rom.sv
//
// stores data about enemy sprites

module enemy_rom2
(
	input 	[7:0] addr,
	output 	[15:0] data
);

	logic[7:0] addr_reg;

	parameter [0:15][15:0] ROM = {

//		8'b10000010, //0 █     █ 
//		8'b01111100, //1  █████  
//		8'b01000100, //2  █   █  
//		8'b01010100, //3  █ █ █  
//		8'b11111110, //4 ███████
//		8'b00111000, //5   ███   
//		8'b01010100, //6  █ █ █  
//		8'b00000000, //7 
//		
//		8'b00100010, //8   █   █ 
//		8'b00111110, //9   █████  
//		8'b00100010, //10  █   █  
//		8'b00101010, //11  █ █ █  
//		8'b01111111, //12 ███████
//		8'b00011100, //13   ███   
//		8'b00101010, //14  █ █ █  
//		8'b00000000, //15
//		
//		8'b00111100, //16   ████  
//		8'b11001110, //17 ██  ███ 
//		8'b00110011, //18   ██  ██
//		8'b11111111, //19 ████████
//		8'b01111110, //20  ██████
//		8'b10010101, //21 █  █ █ █
//		8'b01010101, //22  █ █ █ █
//		8'b00000000, //23 
//		
//		8'b00111100, //24   ████  
//		8'b01110011, //25  ███  ██ 
//		8'b11001100, //26 ██  ██  
//		8'b11111111, //27 ████████
//		8'b01111110, //28  ██████
//		8'b10101001, //29 █ █ █  █
//		8'b10101010, //30 █ █ █ █
//		8'b00000000, //31 
		
		16'b00_00_01_00_00_01_00_00, //32   █  █
		16'b00_10_01_10_10_01_10_00, //33  ██████
		16'b00_10_00_10_10_00_10_00, //34  █ ██ █
		16'b11_10_01_10_10_01_10_11, //35 ████████
		16'b11_10_00_00_00_00_10_11, //36 ██    ██
		16'b00_11_11_11_11_11_11_00, //37  ██████
		16'b11_00_00_00_00_00_00_11, //38 █      █
		16'b00_00_00_00_00_00_00_00, //39
		
		16'b00_00_01_00_00_01_00_00, //32   █  █
		16'b00_10_01_10_10_01_10_00, //33  ██████
		16'b11_10_00_10_10_00_10_11, //34 ██ ██ ██
		16'b11_10_01_10_10_01_10_11, //35 ████████
		16'b00_10_00_00_00_00_10_00, //36  █    █
		16'b11_11_11_11_11_11_11_11, //37 ████████
		16'b00_00_00_00_00_00_00_00, //38       
		16'b00_00_00_00_00_00_00_00, //39
		
// 00 = kosong
//01 = merah
//10 = hijau tua
//11 = kuning
		

		
	};

	assign data = ROM[addr];
	
endmodule 