module starting_map
(
	input logic [7:0] X, Y,
	output logic [7:0] R, G, B
);

    logic [13:0] address;

    always_comb begin
        if (X < 160 && Y < 90)
            address = Y * 14'd160 + X;
        else
            address = 14'd0;
    end

    starting_rom rom (
        .address(address),
        .R(R), .G(G), .B(B)
    );
	 



endmodule

/*
 * ECE385-HelperTools/PNG-To-Txt
 * Author: Rishi Thakkar
 *
 */

module starting_rom
(
    input logic [13:0] address,         // 0 to 23039 (160 x 144)
    output logic [7:0] R, G, B
);

    logic [23:0] mem [0:14399];         // 24-bit per pixel: R[23:16], G[15:8], B[7:0]

    initial begin
        $readmemh("start.txt", mem);    // expects lines like: f6f6f6, 000000, etc.
    end

    assign R = mem[address][23:16];
    assign G = mem[address][15:8];
    assign B = mem[address][7:0];

endmodule

