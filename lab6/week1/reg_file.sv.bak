module register_file
(
	input logic [15:0]INPUT_BUS,
   input logic Clk, Reset, LD_REG,
	input logic [2:0] SR1, SR2, input_DR, 
	output logic [15:0] O_SR1, O_SR2
);
					 
	logic [7:0][15:0] register;
	
	always_ff @ (posedge Clk)
		begin
		
			if (~Reset)			
				begin
				register[0] <= 16'h0000;
				register[1] <= 16'h0000;
				register[2] <= 16'h0000;
				register[3] <= 16'h0000;
				register[4] <= 16'h0000;
				register[5] <= 16'h0000;
				register[6] <= 16'h0000;
				register[7] <= 16'h0000;
				end
			
			else
				begin
					if(LD_REG)			
						begin
							case(input_DR)
								3'b000: register[0] <= INPUT_BUS;
								3'b001: register[1] <= INPUT_BUS;
								3'b010: register[2] <= INPUT_BUS;
								3'b011: register[3] <= INPUT_BUS;
								3'b100: register[4] <= INPUT_BUS;
								3'b101: register[5] <= INPUT_BUS;
								3'b110: register[6] <= INPUT_BUS;
								3'b111: register[7] <= INPUT_BUS;
							endcase
						end
				end
		end
		
		
	always_comb
		begin
			case (SR1)
				3'b000: O_SR1 = register[0];
				3'b001: O_SR1 = register[1];
				3'b010: O_SR1 = register[2];
				3'b011: O_SR1 = register[3];
				3'b100: O_SR1 = register[4];
				3'b101: O_SR1 = register[5];
				3'b110: O_SR1 = register[6];
				3'b111: O_SR1 = register[7];
			endcase
			
			case (SR2)
				3'b000: O_SR2 = register[0];
				3'b001: O_SR2 = register[1];
				3'b010: O_SR2 = register[2];
				3'b011: O_SR2 = register[3];
				3'b100: O_SR2 = register[4];
				3'b101: O_SR2 = register[5];
				3'b110: O_SR2 = register[6];
				3'b111: O_SR2 = register[7];
			endcase
		end
endmodule