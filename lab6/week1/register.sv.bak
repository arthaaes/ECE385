	always_ff @ (posedge Clk) begin
		if (~Reset) // Asynchronous Reset
        Data_out <= 12'b0;
		else if (Load)
        Data_out <= Data_in[11:0];
	end
endmodule

module register_16B 
(
    input logic Clk, Reset, Load,
    input logic [15:0] Data_in,
    output logic [15:0] Data_out
);
	always_ff @ (posedge Clk) begin
		if (~Reset) // Asynchronous Reset
        Data_out <= 16'h0;
		else if (Load)
        Data_out <= Data_in[15:0];
	end
endmodule



