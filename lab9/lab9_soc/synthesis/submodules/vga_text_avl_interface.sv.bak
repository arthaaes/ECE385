/************************************************************************
Avalon-MM Interface VGA Text mode display

Modified for DE2-115 board

Register Map:
0x000-0x0257 : VRAM, 80x30 (2400 byte, 600 word) raster order (first column then row)
0x258        : control register

VRAM Format:
X->
[ 31  30-24][ 23  22-16][ 15  14-8 ][ 7    6-0 ]
[IV3][CODE3][IV2][CODE2][IV1][CODE1][IV0][CODE0]

IVn = Draw inverse glyph
CODEn = Glyph code from IBM codepage 437

Control Register Format:
[[31-25][24-21][20-17][16-13][ 12-9][ 8-5 ][ 4-1 ][   0    ] 
[[RSVD ][FGD_R][FGD_G][FGD_B][BKG_R][BKG_G][BKG_B][RESERVED]

VSYNC signal = bit which flips on every Vsync (time for new frame), used to synchronize software
BKG_R/G/B = Background color, flipped with foreground when IVn bit is set
FGD_R/G/B = Foreground color, flipped with background when Inv bit is set

************************************************************************/
`define NUM_REGS 601 //80*30 characters / 4 characters per register
`define CTRL_REG 600 //index of control register

module vga_text_avl_interface (
    // Avalon Clock Input, note this clock is also used for VGA, so this must be 50Mhz
    // We can put a clock divider here in the future to make this IP more generalizable
    input logic CLK,
    
    // Avalon Reset Input
    input logic RESET,
    
    // Avalon-MM Slave Signals
    input  logic AVL_READ,                  // Avalon-MM Read
    input  logic AVL_WRITE,                 // Avalon-MM Write
    input  logic AVL_CS,                    // Avalon-MM Chip Select
    input  logic [3:0] AVL_BYTE_EN,         // Avalon-MM Byte Enable
    input  logic [9:0] AVL_ADDR,            // Avalon-MM Address
    input  logic [31:0] AVL_WRITEDATA,      // Avalon-MM Write Data
    output logic [31:0] AVL_READDATA,       // Avalon-MM Read Data
    
    // Exported Conduit (mapped to VGA port - make sure you export in Platform Designer)
    output logic [3:0]  red, green, blue,   // VGA color channels (mapped to output pins in top-level)
    output logic hs, vs,                     // VGA HS/VS
    output logic sync, blank, pixel_clk      // Required by DE2-115 video encoder
);

    logic [31:0] LOCAL_REG [`NUM_REGS]; // Registers (VRAM and Control Register)
    
    // Define variables for VRAM and Control Register addresses
    logic [7:0] VRAM [0:2399];    // VRAM for 80x30 grid (2400 bytes total)
    logic [31:0] control_reg;     // Control register for colors

    // VGA Position (used to determine which character to render)
    logic [9:0] DrawX, DrawY;

    // Font ROM Interface (this will be used for sprite/character lookup)
    logic [10:0] sprite_addr;
    logic [7:0] sprite_data;

    // Instantiate VGA Controller (provided in the original code)
    vga_controller vga_controller_instance(
        .Clk(CLK),
        .Reset(RESET),
        .*
    );

    // Instantiate Font ROM (provided in the original code)
    font_rom font_rom_instance(
        .addr(sprite_addr), 
        .data(sprite_data)
    );

    // ========================================================
    // Week 1: Avalon-MM Interface for VRAM and Control Register
    // ========================================================
    always_ff @(posedge CLK) begin
        if (RESET) begin
            // Reset all registers (VRAM and control register)
            for (int i = 0; i < `NUM_REGS; i++) 
                LOCAL_REG[i] <= 32'b0;
        end
        else if (AVL_WRITE && AVL_CS) begin
            // Handle writing to the VRAM and control register (with byte enables)
            if (AVL_ADDR < 2400) begin
                // Write to VRAM (each word can hold 4 characters)
                if (AVL_BYTE_EN[0]) VRAM[AVL_ADDR] <= AVL_WRITEDATA[7:0];
                if (AVL_BYTE_EN[1]) VRAM[AVL_ADDR+1] <= AVL_WRITEDATA[15:8];
                if (AVL_BYTE_EN[2]) VRAM[AVL_ADDR+2] <= AVL_WRITEDATA[23:16];
                if (AVL_BYTE_EN[3]) VRAM[AVL_ADDR+3] <= AVL_WRITEDATA[31:24];
            end else if (AVL_ADDR == `CTRL_REG) begin
                // Write to control register (handle foreground and background colors)
                control_reg <= AVL_WRITEDATA;
            end
        end
        
        // Handle read operations (1-cycle latency)
        AVL_READDATA <= (AVL_READ) ? LOCAL_REG[AVL_ADDR] : 32'b0;
    end

    // ========================================================
    // Week 1: VGA Rendering Logic (Text Mode Display)
    // ========================================================
    always_comb begin
        // Calculate sprite address from VRAM (based on DrawX and DrawY)
        sprite_addr = { 
            VRAM[(DrawY * 80) + DrawX][6:0], // Glyph code from VRAM
            DrawY[3:0]                        // Row inside the glyph (0-15)
        };
    end

    // Pixel output (monochrome with inverse support)
    always_ff @(posedge CLK) begin
        // Get inverse bit (IVn) and glyph code (CODEn) from VRAM
        logic IVn = VRAM[(DrawY * 80) + DrawX][7]; // Inverse bit for current character
        logic pixel_on = sprite_data[7'd7 - DrawX[2:0]] ^ IVn; // XOR for inverse logic
        
        // Use control register to get foreground and background colors
        if (pixel_on) begin // Foreground color
            {red, green, blue} <= {
                control_reg[24:21],  // FGD_R
                control_reg[20:17],  // FGD_G
                control_reg[16:13]   // FGD_B
            };
        end 
        else begin // Background color
            {red, green, blue} <= {
                control_reg[12:9],   // BKG_R
                control_reg[8:5],    // BKG_G
                control_reg[4:1]     // BKG_B
            };
        end
    end

endmodule
